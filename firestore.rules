rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is user authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: is user accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Get user's profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if active and not blocked
    function isUserActive() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().status == "active" && 
        getUserData().blocked == false;
    }

    // Helper: Is Admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == "admin";
    }

    // Rules for User document
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isUserActive());
      
      // User can create their own document at signup.
      // They can update it if they are active and it's their own document, but CANNOT change critical fields like role or blocked.
      allow create: if isOwner(userId) && 
        request.resource.data.role == "user" && 
        request.resource.data.blocked == false &&
        request.resource.data.status == "active" &&
        request.resource.data.uid == userId;
        
      allow update: if (isOwner(userId) && 
        isUserActive() &&
        // Protect role, blocked, status, and uid from self-updating
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'blocked', 'status', 'uid'])))
        || isAdmin();

      allow delete: if isAdmin();
    }

    // Rules for Courses
    match /courses/{courseId} {
      allow read: if isUserActive() || isAdmin();
      allow write: if isAdmin();
    }

    // Rules for Subjects
    match /subjects/{subjectId} {
      allow read: if isUserActive() || isAdmin();
      allow write: if isAdmin();
    }

    // Rules for Lectures
    match /lectures/{lectureId} {
      allow read: if isUserActive() || isAdmin();
      allow write: if isAdmin();
    }

    // Rules for Device Logs
    match /deviceLogs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Rules for Blocked Devices
    match /blockedDevices/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Admin Logs
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
